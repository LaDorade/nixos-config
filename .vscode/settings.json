{
    "nix.enableLanguageServer": true,
    "nix.serverPath": "nil",
    "nix.serverSettings": {
        "nil": {
            "formatting": {
                "command": [
                    "nixfmt"
                ]
            }
        }
    },
    // "nixEnvSelector.nixFile": "${workspaceFolder}/flake.nix",
    "nix.formatterPath": "nixfmt",
    "[nix]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.formatOnSave": true
    }
}